<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f6f7fb;
}

.page-title{
    font-weight:700;
    color:#222;
}

.page-subtitle{
    color:#6c757d;
}

.stat-card{

    background:white;

    border:none;

    border-radius:18px;

    padding:28px;

    box-shadow:0 8px 25px rgba(0,0,0,.05);

    transition:.25s;

    height:100%;
}

.stat-card:hover{

    transform:translateY(-4px);

}

.stat-title{

    color:#777;

    font-size:15px;

    margin-bottom:15px;

}

.stat-value{

    font-size:2.2rem;

    font-weight:700;

    color:#222;

}

.section-card{

    background:white;

    border:none;

    border-radius:18px;

    box-shadow:0 8px 25px rgba(0,0,0,.05);

}

.revenue{

    font-size:3rem;

    font-weight:700;

    color:#ffc107;

}

.btn-dashboard{

    border-radius:10px;

    font-weight:600;

    padding:12px;

}

</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<div class="mb-5">

<h2 class="page-title">

Dashboard

</h2>

<p class="page-subtitle">

Overview of your movie reservation platform.

</p>

</div>

<div class="row g-4">

<div class="col-lg-3 col-md-6">

<div class="stat-card">

<div class="stat-title">

Movies

</div>

<div class="stat-value">

<%= totalMovies %>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="stat-card">

<div class="stat-title">

Users

</div>

<div class="stat-value">

<%= totalUsers %>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="stat-card">

<div class="stat-title">

Shows

</div>

<div class="stat-value">

<%= totalShows %>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="stat-card">

<div class="stat-title">

Reservations

</div>

<div class="stat-value">

<%= totalReservations %>

</div>

</div>

</div>

</div>

<div class="row mt-5 g-4">

<div class="col-lg-7">

<div class="section-card">

<div class="card-body p-5">

<h5 class="mb-4">

Revenue

</h5>

<div class="revenue">

₹ <%= revenue %>

</div>

<p class="text-muted mt-3 mb-0">

Total earnings generated through confirmed bookings.

</p>

</div>

</div>

</div>

<div class="col-lg-5">

<div class="section-card">

<div class="card-body p-5">

<h5 class="mb-4">

Quick Actions

</h5>

<div class="d-grid gap-3">

<a href="/movies/add"

class="btn btn-warning btn-dashboard">

Add Movie

</a>

<a href="/movies"

class="btn btn-outline-dark btn-dashboard">

Manage Movies

</a>

<a href="/reservations/all"

class="btn btn-outline-dark btn-dashboard">

View Reservations

</a>

</div>

</div>

</div>

</div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>