<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f5f6fa;
}

.dashboard-card{

border:none;

border-radius:18px;

transition:.25s;

}

.dashboard-card:hover{

transform:translateY(-5px);

box-shadow:0 15px 35px rgba(0,0,0,.12);

}

.number{

font-size:2.8rem;

font-weight:700;

}

</style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<h1 class="fw-bold mb-5 text-center">

📊 Admin Dashboard

</h1>

<div class="row g-4">

<div class="col-lg-3 col-md-6">

<div class="card dashboard-card shadow bg-primary text-white">

<div class="card-body text-center">

<h5>Total Movies</h5>

<div class="number">

<%= totalMovies %>

</div>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="card dashboard-card shadow bg-success text-white">

<div class="card-body text-center">

<h5>Total Users</h5>

<div class="number">

<%= totalUsers %>

</div>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="card dashboard-card shadow bg-warning">

<div class="card-body text-center">

<h5>Total Shows</h5>

<div class="number">

<%= totalShows %>

</div>

</div>

</div>

</div>

<div class="col-lg-3 col-md-6">

<div class="card dashboard-card shadow bg-danger text-white">

<div class="card-body text-center">

<h5>Reservations</h5>

<div class="number">

<%= totalReservations %>

</div>

</div>

</div>

</div>

</div>

<div class="row mt-5">

<div class="col-lg-6">

<div class="card shadow border-0">

<div class="card-body text-center py-5">

<h4>

💰 Total Revenue

</h4>

<h1 class="display-3 text-success fw-bold">

₹ <%= revenue %>

</h1>

</div>

</div>

</div>

<div class="col-lg-6">

<div class="card shadow border-0">

<div class="card-body">

<h4 class="mb-4">

⚡ Quick Actions

</h4>

<div class="d-grid gap-3">

<a href="/movies/add" class="btn btn-warning fw-bold">

➕ Add Movie

</a>

<a href="/movies" class="btn btn-primary fw-bold">

🎬 Manage Movies

</a>

<a href="/reservations" class="btn btn-success fw-bold">

🎟 Reservations

</a>

</div>

</div>

</div>

</div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>