<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>404 | Page Not Found</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

html,
body{

    height:100%;

}

body{

    background:#f8f9fb;

    display:flex;

    flex-direction:column;

}

main{

    flex:1;

    display:flex;

    justify-content:center;

    align-items:center;

}

.error-card{

    background:white;

    border:none;

    border-radius:20px;

    box-shadow:0 10px 30px rgba(0,0,0,.08);

    padding:60px;

    max-width:650px;

    text-align:center;

}

.error-code{

    font-size:7rem;

    font-weight:700;

    color:#ffc107;

    line-height:1;

}

.error-title{

    font-weight:700;

    margin-top:20px;

    color:#212529;

}

.error-text{

    color:#6c757d;

    margin-top:15px;

    margin-bottom:35px;

    font-size:1.05rem;

}

.btn-home{

    background:#ffc107;

    border:none;

    color:#212529;

    font-weight:600;

    padding:12px 28px;

    border-radius:10px;

}

.btn-home:hover{

    background:#ffca2c;

}

</style>

</head>

<body>

<%- include("partials/navbar") %>

<main>

<div class="error-card">

<div class="error-code">

404

</div>

<h2 class="error-title">

Page Not Found

</h2>

<p class="error-text">

The page you are looking for doesn't exist or may have been moved.
Please check the URL or return to the homepage.

</p>

<div class="d-flex justify-content-center gap-3">

<a
href="/"
class="btn btn-home">

Home

</a>

<a
href="/movies"
class="btn btn-outline-dark">

Browse Movies

</a>

</div>

</div>

</main>

<footer class="text-center py-3 border-top bg-white">

<span class="text-muted">

© 2026 MovieHub

</span>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>