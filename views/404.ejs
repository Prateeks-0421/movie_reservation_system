<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found | MovieHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #0f0f0f;
            -webkit-font-smoothing: antialiased;
        }

        main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 0;
        }

        .error-container {
            width: 100%;
            max-width: 440px;
            margin: auto;
            text-align: center;
            padding: 0 16px;
        }

        .status-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f0f0f;
            letter-spacing: -0.3px;
            margin-top: 16px;
        }

        .status-desc {
            font-size: 14px;
            color: #606060;
            margin-top: 6px;
            line-height: 1.5;
            margin-bottom: 28px;
        }

        /* Clean information panel matching global forms */
        .info-panel {
            background-color: #f9f9f9;
            border: 1px solid #efefef;
            border-radius: 6px;
            padding: 18px;
            text-align: left;
            margin-bottom: 32px;
            font-size: 13px;
            color: #606060;
            line-height: 1.6;
        }

        /* Platform action buttons */
        .btn-platform {
            font-size: 13px;
            font-weight: 500;
            background: #0f0f0f;
            color: #ffffff;
            border-radius: 18px;
            padding: 8px 20px;
            border: none;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-platform:hover {
            background: #272727;
            color: #ffffff;
        }

        .btn-platform-outline {
            font-size: 13px;
            font-weight: 500;
            color: #0f0f0f;
            border: 1px solid #d3d3d3;
            border-radius: 18px;
            padding: 7px 20px;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-platform-outline:hover {
            background: #f2f2f2;
            color: #0f0f0f;
        }

        footer {
            background: #ffffff;
            border-top: 1px solid #efefef;
            font-size: 12px;
        }

        .footer-text {
            color: #606060;
        }
    </style>
</head>

<body>

    

    <main>
        <div class="error-container">

            <!-- Clean Alert Icon Header -->
            <div class="mb-2">
                <svg width="36" height="36" fill="none" stroke="#606060" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
            </div>
            
            <h1 class="status-title">Page Not Found</h1>
            <p class="status-desc">The specific path index requested could not be resolved by the server router.</p>

            <!-- Text Warning Component -->
            <div class="info-panel">
                <strong>Notice:</strong> The endpoint may have been modified, unmapped, or structural changes might have broken the link layout. Verify your parameter input data or return to the main route dashboard.
            </div>

            <!-- Context Actions -->
            <div class="d-flex justify-content-center gap-2">
                <a href="/" class="btn-platform">
                    Go Home
                </a>
                <a href="/movies" class="btn-platform-outline">
                    Browse Catalog
                </a>
            </div>

        </div>
    </main>

    <footer class="py-3 text-center">
        <div class="container">
            <span class="footer-text">© 2026 MovieHub</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>