<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= movie.title %> | MovieHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #0f0f0f;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            max-width: 950px;
            margin: auto;
        }

        /* Split details structural row */
        .movie-detail-row {
            display: flex;
            gap: 40px;
            padding-bottom: 40px;
            border-bottom: 1px solid #efefef;
        }

        .poster-pane {
            width: 240px;
            flex-shrink: 0;
        }

        .poster-frame {
            width: 100%;
            border-radius: 8px;
            overflow: hidden;
            background: #f8f9fa;
            border: 1px solid #efefef;
        }

        .poster-img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }

        /* Clean unified titles */
        .movie-title {
            font-size: 26px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .ui-tag {
            font-size: 11px;
            font-weight: 500;
            padding: 3px 8px;
            border-radius: 4px;
            background: #f2f2f2;
            color: #606060;
            display: inline-block;
        }

        .movie-description {
            font-size: 14px;
            color: #606060;
            line-height: 1.6;
            margin: 20px 0;
        }

        /* Clean inline metadata fields */
        .meta-group {
            font-size: 13px;
            color: #606060;
            margin-bottom: 24px;
        }

        .meta-label {
            color: #909090;
            font-weight: 400;
            margin-right: 4px;
        }

        /* Action elements consistent with platform */
        .btn-platform {
            font-size: 13px;
            font-weight: 500;
            background: #0f0f0f;
            color: #ffffff;
            border-radius: 18px;
            padding: 8px 16px;
            border: none;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-platform:hover {
            background: #272727;
            color: #ffffff;
        }

        .btn-platform-outline {
            font-size: 13px;
            font-weight: 500;
            color: #0f0f0f;
            border: 1px solid #d3d3d3;
            border-radius: 18px;
            padding: 7px 16px;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-platform-outline:hover {
            background: #f2f2f2;
            color: #0f0f0f;
        }

        .btn-platform-danger {
            font-size: 13px;
            font-weight: 500;
            background: transparent;
            color: #9b1c1c;
            border: 1px solid #fde8e8;
            border-radius: 18px;
            padding: 7px 16px;
            transition: background 0.2s;
        }

        .btn-platform-danger:hover {
            background: #fdf2f2;
        }

        /* Showtimes Section */
        .section-heading {
            font-size: 18px;
            font-weight: 600;
            margin-top: 40px;
            margin-bottom: 20px;
            color: #0f0f0f;
        }

        /* Minimal list row format for available sessions */
        .showtime-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0;
            border-bottom: 1px solid #f5f5f5;
        }

        .showtime-row:last-child {
            border-bottom: none;
        }

        .showtime-main-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .showtime-time {
            font-size: 15px;
            font-weight: 600;
            color: #0f0f0f;
            width: 70px;
        }

        .showtime-date {
            font-size: 13px;
            color: #606060;
        }

        .showtime-meta {
            display: flex;
            gap: 12px;
            font-size: 13px;
            color: #606060;
        }

        .showtime-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .text-price {
            font-weight: 600;
            color: #0f0f0f;
        }

        /* Responsive stack styling */
        @media (max-width: 768px) {
            .movie-detail-row {
                flex-direction: column;
                gap: 24px;
            }
            .poster-pane {
                width: 160px;
            }
            .showtime-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            .showtime-actions {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container py-5">
        <div class="wrapper">
            
            <!-- Movie Layout Core Information -->
            <div class="movie-detail-row">
                
                <div class="poster-pane">
                    <div class="poster-frame">
                        <img src="<%= movie.posterurl %>" class="poster-img" alt="<%= movie.title %>">
                    </div>
                </div>

                <div class="flex-grow-1">
                    <h1 class="movie-title"><%= movie.title %></h1>
                    
                    <div class="d-flex gap-2 my-2">
                        <span class="ui-tag"><%= movie.genre %></span>
                        <span class="ui-tag"><%= movie.language %></span>
                    </div>

                    <p class="movie-description">
                        <%= movie.description %>
                    </p>

                    <div class="meta-group">
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <span class="meta-label">Duration:</span> <%= movie.duration %> minutes
                            </div>
                            <div class="col-sm-6">
                                <span class="meta-label">Release:</span> <%= new Date(movie.releasedate).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap align-items-center">
                        <a href="/movies" class="btn-platform-outline">← Catalog</a>
                        <a href="/movies/comments/<%= movie.id %>" class="btn-platform-outline">Reviews</a>
                        
                        <% if(locals.user && locals.user.role === "ADMIN"){ %>
                            <a href="/showtimes/add/<%= movie.id %>" class="btn-platform-outline">+ Add Show</a>
                            <form action="/movies/delete/<%= movie.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this movie?');" class="d-inline">
                                <button type="submit" class="btn-platform-danger">Delete</button>
                            </form>
                        <% } %>
                    </div>
                </div>

            </div>

            <!-- Showtimes Implementation Module -->
            <div class="showtimes-section">
                <h2 class="section-heading">Available Showtimes</h2>

                <% if(showtime.length > 0) { %>
                    <div class="showtime-list-container">
                        <% let flag = 1; %>
                        <% showtime.forEach((show) => { %>
                            <% if(show.showtime > new Date()) { %>
                                <% flag = 0; %>
                                <div class="showtime-row">
                                    
                                    <div class="showtime-main-info">
                                        <div class="showtime-time">
                                            <%= new Date(show.showtime).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" }) %>
                                        </div>
                                        <div class="showtime-date">
                                            <%= new Date(show.showtime).toLocaleDateString("en-IN", { weekday: "short", day: "numeric", month: "short" }) %>
                                        </div>
                                    </div>

                                    <div class="showtime-meta">
                                        <div><span class="meta-label">Screen</span> <%= show.screen %></div>
                                        <div>•</div>
                                        <div><%= show.totalSeats %> seats</div>
                                    </div>

                                    <div class="showtime-actions">
                                        <span class="text-price me-2">₹<%= show.price %></span>
                                        <a href="/reservations/<%= show.id %>" class="btn-platform">Book</a>
                                        
                                        <% if(locals.user && locals.user.role === "ADMIN"){ %>
                                            <a href="/showtimes/<%= show.id %>" class="btn-platform-danger py-1 px-2" style="font-size: 11px;">Remove</a>
                                        <% } %>
                                    </div>

                                </div>
                            <% } %>
                        <% }) %>

                        <% if(flag == 1) { %>
                            <p class="text-muted fs-6 py-3">Noschedules currently avaiible for this movie.</p>
                        <% } %>
                    </div>
                <% } else { %>
                    <p class="text-muted fs-6 py-3">Noschedules currently avaiible for this movie</p>
                <% } %>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>