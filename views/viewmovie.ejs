<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= movie.title %> | MovieHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:#f5f6fa;
        }

        .movie-card{
            border-radius:20px;
            overflow:hidden;
        }

        .movie-poster{
            height:600px;
            object-fit:contain;
            background:white;
        }

        .show-card{
            border-radius:18px;
            transition:.3s;
            cursor:pointer;
            border:none;
        }

        .show-card:hover{
            transform:translateY(-8px);
            box-shadow:0 18px 35px rgba(0,0,0,.15)!important;
            border:2px solid #ffc107;
        }

        .show-card .btn{
            border-radius:30px;
        }

        .badge-custom{
            font-size:.9rem;
            padding:8px 15px;
        }

    </style>

</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<div class="card movie-card shadow-lg border-0">

<div class="row g-0">

<!-- Poster -->

<div class="col-lg-4">

<div class="d-flex justify-content-center align-items-center h-100 bg-white">

<img
src="<%= movie.posterurl %>"
class="img-fluid movie-poster"
style="object-fit:cover;"
alt="<%= movie.title %>">

</div>

</div>

<!-- Details -->

<div class="col-lg-8">

<div class="card-body p-5">

<h1 class="fw-bold display-5">

<%= movie.title %>

</h1>

<div class="my-3">

<span class="badge bg-warning text-dark badge-custom">

<%= movie.genre %>

</span>

<span class="badge bg-dark badge-custom">

<%= movie.language %>

</span>

</div>

<p class="text-secondary fs-5">

<%= movie.description %>

</p>

<hr>

<div class="row mt-4">

<div class="col-md-4">

<h6 class="fw-bold">

⏱ Duration

</h6>

<p>

<%= movie.duration %> Minutes

</p>

</div>

<div class="col-md-4">

<h6 class="fw-bold">

📅 Release Date

</h6>

<p>

<%= new Date(movie.releasedate).toLocaleDateString() %>

</p>

</div>

</div>

<div class="mt-4 d-flex gap-3 flex-wrap">

<a href="/movies"
class="btn btn-outline-dark">

← Back

</a>

<% if(locals.user && locals.user.role==="ADMIN"){ %>

<a href="/showtimes/add/<%= movie.id %>"
class="btn btn-warning fw-bold">

➕ Add Show

</a>
<form action="/movies/delete/<%= movie.id %>" method="POST"
          onsubmit="return confirm('Are you sure you want to delete this movie?');"
          class="d-inline">

        <button type="submit" class="btn btn-danger px-4 fw-bold">
            🗑 Delete Movie
        </button>

    </form>

<% } %>

</div>

</div>

</div>

</div>

</div>

<!-- SHOWTIMES -->

<div class="mt-5">

<h2 class="fw-bold mb-4">

🎟 Available Shows

</h2>

<% if(showtime.length>0  ){ %>

<div class="row g-4">
    <% let flag = 1 ;  %>

<% showtime.forEach((show)=>{ 
    if(show.showtime > new Date()){
    %>
   <% flag = 0 ; %>
<div class="col-lg-4 col-md-6">

<a href="/reservations/<%= show.id %>"
class="text-decoration-none">

<div class="card show-card shadow-sm">

<div class="card-body text-center p-4">

<div class="mb-3">

<span class="badge bg-dark px-3 py-2">

Screen <%= show.screen %>

</span>

</div>

<h3 class="fw-bold text-primary">

<%= new Date(show.showtime).toLocaleTimeString("en-IN",{

hour:"2-digit",

minute:"2-digit"

}) %>

</h3>

<p class="text-muted mb-4">

<%= new Date(show.showtime).toLocaleDateString("en-IN",{

weekday:"long",

day:"numeric",

month:"long",

year:"numeric"

}) %>

</p>

<div class="d-flex justify-content-center gap-2 mb-4">

<span class="badge bg-success fs-6">

₹ <%= show.price %>

</span>

<span class="badge bg-secondary fs-6">

<%= show.totalSeats %> Seats

</span>

</div>

<button class="btn btn-warning w-100 fw-bold">

Book Now →

</button>

</div>

</div>

</a>

</div>
<% }   %>
 
<% }) %>

<% if(flag == 1 ){ %>

<div class="card border-0 shadow-sm">

<div class="card-body text-center py-5">

<h4 class="fw-bold">

No Shows Available

</h4>

<p class="text-muted">

Shows will appear here after the admin schedules them.

</p>

</div>

</div>

<% } %>

</div>

<% } else { %>

<div class="card border-0 shadow-sm">

<div class="card-body text-center py-5">

<h4 class="fw-bold">

No Shows Available

</h4>

<p class="text-muted">

Shows will appear here after the admin schedules them.

</p>

</div>

</div>

<% } %>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>