<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Book Tickets | MovieHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:#f5f6fa;
        }

        .poster{
            height:420px;
            object-fit:contain;
            background:white;
        }

        .seat{
            width:50px;
            height:50px;
            border:2px solid #28a745;
            border-radius:10px;
            display:flex;
            justify-content:center;
            align-items:center;
            cursor:pointer;
            font-weight:bold;
            transition:.2s;
            user-select:none;
        }

      .booked{

background:#dc3545;

border-color:#dc3545;

color:white;

cursor:not-allowed;

pointer-events:none;

opacity:.8;

} 

        .seat:hover{
            background:#28a745;
            color:white;
        }

        .selected{
            background:#ffc107 !important;
            border-color:#ffc107 !important;
            color:black !important;
        }

    </style>

</head>

<body>

<%- include("partials/navbar") %>


        <% if(locals.error){  %>
            <div class="alert alert-danger mt-3 ms-3 me-3" role="alert">
              <%= error %>
             </div>
            <% } %>

<div class="container py-5">

<div class="row">

<div class="col-lg-4">

<div class="card shadow border-0">

<img
src="<%= show.movie.posterurl %>"
class="poster card-img-top"
style="object-fit:cover;">

<div class="card-body">

<h3 class="fw-bold">

<%= show.movie.title %>

</h3>

<span class="badge bg-warning text-dark">

<%= show.movie.genre %>

</span>

<span class="badge bg-dark">

<%= show.movie.language %>

</span>

<hr>

<p>

📅

<%= new Date(show.showdate).toLocaleDateString() %>

</p>

<p>

🕒

<%= new Date(show.showtime).toLocaleTimeString([],{
hour:"2-digit",
minute:"2-digit"
}) %>

</p>

<p>

🎥 Screen <%= show.screen %>

</p>

<p>

💰 ₹<%= show.price %> / Seat

</p>

</div>

</div>

</div>

<div class="col-lg-8">

<div class="card shadow border-0">

<div class="card-body">

<h2 class="fw-bold mb-4">

Select Your Seats

</h2>

<%
const seatsPerRow = 10 ;
const totalRows = Math.ceil(show.totalSeats / seatsPerRow);
%>

<div class="d-flex flex-column gap-3">

<% for(let r = 0; r < totalRows; r++){ %>

<div class="d-flex justify-content-center gap-2">

<%
const rowLetter = String.fromCharCode(65 + r);

for(let c = 1; c <= seatsPerRow; c++){

    const seatNumber = r * seatsPerRow + c;

    if(seatNumber > show.totalSeats) break;
%>

<div
    class="seat <%= bookedSeats.includes(rowLetter + c) ? 'booked' : '' %>"
    data-seat="<%= rowLetter + c %>">

    <%= rowLetter + c %>

</div>

<% } %>

</div>

<% } %>

</div>


<hr class="my-4">

<h5>

Selected Seats:

<span id="selectedSeats">

None

</span>

</h5>

<h4 class="mt-3">

Total :

₹

<span id="totalPrice">

0

</span>

</h4>

<form
action="/reservations/<%= show.id %>"
method="POST">

<input
type="hidden"
name="seats"
id="seatInput">

<button
class="btn btn-warning btn-lg mt-4 fw-bold">

Confirm Booking

</button>

</form>

</div>

</div>

</div>

</div>

</div>

<script>

const price = <%= show.price %>;

const seats=[];

const allSeats=document.querySelectorAll(".seat");

const seatInput=document.getElementById("seatInput");

const selected=document.getElementById("selectedSeats");

const total=document.getElementById("totalPrice");

allSeats.forEach(seat=>{

seat.addEventListener("click",()=>{

seat.classList.toggle("selected");

const value=seat.dataset.seat;

if(seats.includes(value)){

seats.splice(seats.indexOf(value),1);

}else{

seats.push(value);

}

selected.innerText=seats.length?seats.join(", "):"None"; 

total.innerText=seats.length*price;

seatInput.value=seats.join(",");

});

});

</script>

</body>

</html>


















