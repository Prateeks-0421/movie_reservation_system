<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Movie Reservation System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include("partials/navbar") %>

        <% if(locals.error){  %>
            <div class="alert alert-danger mt-3 ms-3 me-3" role="alert">
              <%= error %>
             </div>
            <% } %>

    <section class="container py-5">

        <div class="text-center">

            <h1 class="display-4 fw-bold">
                Book Your Favorite Movies
            </h1>

            <p class="lead mt-3">
                Browse movies, select your seats, and reserve tickets in just a few clicks.
            </p>

            <a href="/movies" class="btn btn-custom">
                Browse Movies
            </a>

        </div>

    </section>

    <footer class="text-center py-4 border-top mt-5">
        <p class="mb-0">
            © 2026 Movie Reservation System
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/js/main.js"></script>

</body>
</html>