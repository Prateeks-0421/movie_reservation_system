<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>MovieHub</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/style.css">

<style>

html,body{
    height:100%;
}

body{
    display:flex;
    flex-direction:column;
    background:#f8f9fb;
}

main{
    flex:1;
}

.hero{

    padding:90px 0 70px;

}

.hero h1{

    font-size:3rem;
    font-weight:700;
    color:#1f2937;
    line-height:1.2;

}

.hero p{

    color:#6c757d;
    font-size:1.1rem;
    max-width:620px;
    margin:25px auto;

}

.btn-main{

    background:#ffc107;
    color:#000;
    font-weight:600;
    padding:12px 34px;
    border-radius:10px;
    transition:.25s;

}

.btn-main:hover{

    background:#ffca2c;

}

.stats{

    margin-top:70px;

}

.stat-card{

    background:white;
    border:none;
    border-radius:16px;
    box-shadow:0 8px 25px rgba(0,0,0,.05);
    padding:28px;
    transition:.25s;

}

.stat-card:hover{

    transform:translateY(-5px);

}

.stat-number{

    font-size:2rem;
    font-weight:700;

}

.features{

    padding:80px 0;

}

.feature{

    background:white;
    border:none;
    border-radius:18px;
    box-shadow:0 8px 25px rgba(0,0,0,.05);
    padding:35px;
    transition:.25s;

}

.feature:hover{

    transform:translateY(-6px);

}

.feature-icon{

    font-size:40px;

}

footer{

    background:white;
    border-top:1px solid #ececec;

}

</style>

</head>

<body>

<%- include("partials/navbar") %>

<main>

<section class="hero">

<div class="container text-center">

<% if(locals.error){ %>

<div class="alert alert-danger">

<%= error %>

</div>

<% } %>

<h1>

Book Movie Tickets Effortlessly

</h1>

<p>

Experience a modern movie reservation platform with secure payments,
real-time seat selection, and instant booking confirmations.

</p>

<a href="/movies" class="btn btn-main">

Browse Movies

</a>



</div>

</section>



</main>

<footer class="py-4">

<div class="container">

<div class="d-flex justify-content-between">

<span class="text-muted">

© 2026 MovieHub

</span>

<span class="text-muted">

Built with Node.js • Express • Prisma • PostgreSQL

</span>

</div>

</div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>