<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MovieHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            background: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #0f0f0f;
            -webkit-font-smoothing: antialiased;
        }

        main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 0;
        }

        .hero-container {
            max-width: 580px;
            margin: auto;
        }

        /* Monochromatic, clean heading */
        .hero-title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #0f0f0f;
            margin-bottom: 12px;
        }

        /* Clean descriptive text */
        .hero-desc {
            color: #606060;
            font-size: 14px;
            line-height: 1.5;
            margin-bottom: 24px;
        }

        /* Production-ready action button */
        .btn-platform {
            background: #0f0f0f;
            color: #ffffff;
            font-size: 14px;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 20px;
            border: none;
            transition: background 0.2s ease;
            display: inline-flex;
            align-items: center;
        }

        .btn-platform:hover {
            background: #272727;
            color: #ffffff;
        }

        /* Color-coordinated minimalist error badge */
        .alert-custom-error {
            background-color: #fdf2f2;
            border: 1px solid #fde8e8;
            color: #9b1c1c;
            font-size: 13px;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 24px;
            text-align: left;
        }

        /* Structural Footer */
        footer {
            background: #ffffff;
            border-top: 1px solid #efefef;
            font-size: 12px;
        }
        
        .footer-text {
            color: #606060;
        }
    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <main>
        <div class="container text-center">
            <div class="hero-container">
                
                <% if(locals.error){ %>
                    <div class="alert alert-custom-error d-flex align-items-center">
                        <svg class="me-2" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                        </svg>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <h1 class="hero-title">Book Movie Tickets</h1>
                
                <p class="hero-desc">
                    Access real-time seat validation, secure transaction flows, and instantaneous digital ticket assignment.
                </p>

                <a href="/movies" class="btn btn-platform">
                    Browse Catalogue
                </a>

            </div>
        </div>
    </main>

    <footer class="py-3">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <span class="footer-text">© 2026 MovieHub</span>
                <span class="footer-text text-end"></span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>