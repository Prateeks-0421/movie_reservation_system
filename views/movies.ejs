<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movies | MovieHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            background: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #0f0f0f;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            max-width: 1050px;
            margin: auto;
        }

        .page-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f0f0f;
            letter-spacing: -0.3px;
        }

        .page-desc {
            font-size: 14px;
            color: #606060;
            margin-top: 2px;
        }

        /* Minimal catalog card style */
        .catalog-card {
            background: #ffffff;
            border: 1px solid #efefef;
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
            transition: border-color 0.2s ease;
        }

        .catalog-card:hover {
            border-color: #d3d3d3;
        }

        .thumbnail-frame {
            width: 100%;
            height: 240px;
            background: #f8f9fa;
            overflow: hidden;
            border-bottom: 1px solid #efefef;
        }

        .thumbnail-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .card-content {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .movie-title {
            font-size: 16px;
            font-weight: 600;
            color: #0f0f0f;
            margin-bottom: 4px;
        }

        .movie-snippet {
            font-size: 13px;
            color: #606060;
            line-height: 1.5;
            margin-bottom: 12px;
        }

        /* Uniform custom tags */
        .ui-tag {
            font-size: 11px;
            font-weight: 500;
            padding: 3px 8px;
            border-radius: 4px;
            background: #f2f2f2;
            color: #606060;
            display: inline-block;
        }

        .meta-line {
            font-size: 12px;
            color: #909090;
            margin-bottom: 4px;
        }

        .meta-value {
            color: #606060;
        }

        /* Clean action links */
        .btn-platform {
            font-size: 13px;
            font-weight: 500;
            background: #0f0f0f;
            color: #ffffff;
            border-radius: 18px;
            padding: 8px 16px;
            border: none;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-platform:hover {
            background: #272727;
            color: #ffffff;
        }

        .btn-platform-outline {
            font-size: 13px;
            font-weight: 500;
            color: #0f0f0f;
            border: 1px solid #d3d3d3;
            border-radius: 18px;
            padding: 7px 16px;
            transition: background 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-platform-outline:hover {
            background: #f2f2f2;
            color: #0f0f0f;
        }

        /* Custom minimal error box */
        .alert-custom-error {
            background-color: #fdf2f2;
            border: 1px solid #fde8e8;
            color: #9b1c1c;
            font-size: 13px;
            border-radius: 6px;
            padding: 10px 16px;
        }
    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container py-5">
        <div class="wrapper">

            <!-- Title & Context Area -->
            <div class="d-flex justify-content-between align-items-start mb-4 pb-3 border-bottom">
                <div>
                    <h1 class="page-title">Movies</h1>
                    <p class="page-desc">Available Movies details </p>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <% if(locals.error){ %>
                        <div class="alert alert-custom-error m-0" role="alert">
                            <%= error %>
                        </div>
                    <% } %>

                    <% if(locals.user && locals.user.role === "ADMIN"){ %>
                        <a href="/movies/add" class="btn-platform-outline">
                            + Add Entry
                        </a>
                    <% } %>
                </div>
            </div>

            <!-- Empty State Conditions -->
            <% if(movies.length === 0){ %>
                <div class="text-center py-5">
                    <p class="text-muted fs-6">No Movies registered yet . contact adminstrator </p>
                </div>
            <% } else { %>

                <!-- Responsive Grid Base -->
                <div class="row g-4">
                    <% movies.forEach(movie => { %>
                        <div class="col-sm-6 col-md-4">
                            <div class="catalog-card">
                                
                                <div class="thumbnail-frame">
                                    <img src="<%= movie.posterurl %>" class="thumbnail-img" alt="<%= movie.title %>">
                                </div>

                                <div class="card-content">
                                    <h3 class="movie-title"><%= movie.title %></h3>
                                    
                                    <p class="movie-snippet">
                                        <%= movie.description.substring(0, 85) %>...
                                    </p>

                                    <div class="d-flex gap-2 mb-3">
                                        <span class="ui-tag"><%= movie.genre %></span>
                                        <span class="ui-tag"><%= movie.language %></span>
                                    </div>

                                    <div class="mt-auto pt-2 border-top">
                                        <div class="meta-line">
                                            <span>Duration:</span> <span class="meta-value"><%= movie.duration %> mins</span>
                                        </div>
                                        <div class="meta-line mb-3">
                                            <span>Released:</span> <span class="meta-value"><%= new Date(movie.releasedate).toLocaleDateString("en-IN", { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                        </div>

                                        <a href="/movies/<%= movie.id %>" class="btn-platform w-100">
                                             view Movie
                                        </a>
                                    </div>

                                </div>

                            </div>
                        </div>
                    <% }) %>
                </div>

            <% } %>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>