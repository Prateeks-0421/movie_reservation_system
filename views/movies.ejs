<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movies | MovieHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-5">

            <div>
                <h2 class="fw-bold">🎬 All Movies</h2>
                <p class="text-muted mb-0">
                    Browse all available movies.
                </p>
            </div>

             <% if(locals.error){  %>
            <div class="alert alert-danger mt-3 ms-3 me-3" role="alert">
              <%= error %>
             </div>
            <% } %>


            <% if(locals.user && locals.user.role === "ADMIN"){ %>
                <a href="/movies/add" class="btn btn-warning fw-semibold px-4">
                    + Add Movie
                </a>
            <% } %>

        </div>

        <% if(movies.length === 0){ %>

            <div class="alert alert-info text-center shadow-sm">
                <h4>No Movies Available</h4>
                <p class="mb-0">Admin hasn't added any movies yet.</p>
            </div>

        <% } else { %>

        <div class="row g-4">

            <% movies.forEach(movie => { %>

                <div class="col-md-6 col-lg-4">

                    <div class="card shadow-sm border-0 h-100">

                        <img
                            src="<%= movie.posterurl %>"
                            class="card-img-top"
                            alt="<%= movie.title %>"
                         style="height:320px; object-fit:fit; background-color:#f8f9fa;">

                        <div class="card-body d-flex flex-column">

                            <h4 class="fw-bold">
                                <%= movie.title %>
                            </h4>

                            <p class="text-muted mb-3">
                                <%= movie.description.substring(0,100) %>...
                            </p>

                            <div class="mb-3">

                                <span class="badge bg-warning text-dark me-2">
                                    <%= movie.genre %>
                                </span>

                                <span class="badge bg-dark">
                                    <%= movie.language %>
                                </span>

                            </div>

                            <p class="mb-1">
                                <strong>Duration:</strong>
                                <%= movie.duration %> mins
                            </p>

                            <p class="mb-4">
                                <strong>Release:</strong>
                                <%= movie.releasedate.toLocaleDateString() %>
                            </p>

                            <div class="mt-auto">

                                <a
                                    href="/movies/<%= movie.id %>"
                                    class="btn btn-warning w-100 fw-semibold">

                                    View Details

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

        <% } %>

    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>