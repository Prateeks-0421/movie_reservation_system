<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Movie Reservation System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include("partials/navbar") %>

       <% if(locals.error){  %>
            <div class="alert alert-danger mt-3 ms-3 me-3 " role="alert">
              <%= error %>
             </div>
            <% } %>

     <form class="mt-5" method="POST" action="/auth/login">

   <div class="mb-3 ms-3">
    <label for="exampleInputEmail1" class="form-label">Email address</label>
    <input type="email" class="form-control" id="email" aria-describedby="emailHelp" name="email" required >
   </div>
   <div class="mb-3 ms-3">
    <label for="exampleInputPassword1" class="form-label">Password</label>
    <input type="password" class="form-control" id="password" name="password" required>
   </div>

   <button type="submit" class="btn btn-custom ms-3">Submit</button>
   </form>

    <footer class="text-center py-4 border-top mt-5">
        <p class="mb-0">
            © 2026 Movie Reservation System
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/js/main.js"></script>

</body>
</html>